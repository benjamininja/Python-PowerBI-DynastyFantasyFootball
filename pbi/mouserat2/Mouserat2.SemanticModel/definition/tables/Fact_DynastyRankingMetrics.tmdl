/// Long (EAV) dynasty metrics: one row per snapshot, source, player, format, and metric_key. Source-specific stats live here so new sources add rows, not columns.
table Fact_DynastyRankingMetrics
	lineageTag: c9958674-0792-4495-82c2-d55231b62c0d

	/// Date the rankings were captured. Use the latest snapshot for current values; the table is a manual-cadence time series.
	column SnapshotDate
		dataType: dateTime
		formatString: yyyy-mm-dd
		lineageTag: d274cc23-6797-43ce-84b9-17d775cb150f
		summarizeBy: none
		sourceColumn: snapshot_date

		variation Variation
			isDefault
			relationship: d379b904-5978-47ff-b866-ad0aae8a05a3
			defaultHierarchy: LocalDateTable_a4aa6594-b0e8-4690-b46e-21b85320987a.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = snapshot|date|as of date|capture date|snapshot date

		annotation SynonymCollection = ["snapshot","date","as of date","capture date","snapshot date"]

	/// The source's own player id/slug. Not unique across sources; combine with source_name (see source_uid) for identity.
	column SourcePlayerID
		dataType: string
		lineageTag: 4158490d-246b-43e7-a4b6-3aeef7507882
		summarizeBy: none
		sourceColumn: source_player_id

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = source player id|player slug|source id|provider player id

		annotation SynonymCollection = ["source player id","player slug","source id","provider player id"]

	/// League format the metric applies to (SF superflex, TEPP tight-end premium, IDP). Format-agnostic metrics repeat across formats.
	column Format
		dataType: string
		lineageTag: c3b3e4fe-b294-4cc7-af4d-3785fb2febf6
		summarizeBy: none
		sourceColumn: format

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = format|league format|scoring format|superflex|tepp

		annotation SynonymCollection = ["format","league format","scoring format","superflex","tepp"]

	/// Stable metric key joining to Dim_DynastyMetric (e.g. value, adp, proj_3yr, kept).
	column MetricKey
		dataType: string
		lineageTag: b5fff951-dbf3-4fab-bf68-6ef09540f0bd
		summarizeBy: none
		sourceColumn: metric_key

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = metric|metric key|stat|measure key

		annotation SynonymCollection = ["metric","metric key","stat","measure key"]

	/// Numeric value of the metric (blank for text metrics). Defaults to AVERAGE; per metric_key, blend duplicates across format/source rather than summing.
	column MetricNum
		dataType: double
		lineageTag: e1e692ac-495d-4f1a-8a81-07e6af5ab5b8
		summarizeBy: sum
		sourceColumn: metric_num

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

		annotation Synonyms = value|metric value|number|stat value|amount

		annotation SynonymCollection = ["value","metric value","number","stat value","amount"]

	/// Text value of the metric (e.g. the Analysis blurb); blank for numeric metrics.
	column MetricText
		dataType: string
		lineageTag: d73d92c2-99a5-4d1e-8d96-681136a476fd
		summarizeBy: none
		sourceColumn: metric_text

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = text|metric text|note|comment|description

		annotation SynonymCollection = ["text","metric text","note","comment","description"]

	/// Player identity key = source_name|source_player_id. Single-column key linking to the crosswalk; the metrics grain's only path to player identity.
	column SourceUID
		dataType: string
		lineageTag: 7b44de5e-7eca-4f88-9d00-94e5ca27a16b
		summarizeBy: none
		sourceColumn: source_uid

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = source uid|player uid|identity key|unique id

		annotation SynonymCollection = ["source uid","player uid","identity key","unique id"]

	/// nflverse universal player id; the metrics grain's own link to Dim_NFLPlayers, independent of the ranking backbone.
	column GSISID
		dataType: string
		lineageTag: 2f6fc8be-6364-4d43-9969-22862132dc18
		summarizeBy: none
		sourceColumn: gsis_id

		annotation SummarizationSetBy = Automatic

		annotation Synonyms = gsis id|player id|nfl id|gsis

		annotation SynonymCollection = ["gsis id","player id","nfl id","gsis"]

	/// ETL partition/load key (replace-by-source), kept on the fact by exception: source attribution for ANALYSIS lives on Dim_DynastyMetric.SourceName (one source per MetricKey). Hidden -- use Dim_DynastyMetric[SourceName] in visuals.
	column source_name
		dataType: string
		isHidden
		lineageTag: ff239fa3-2901-4590-9f76-f937f4f603e4
		summarizeBy: none
		sourceColumn: source_name

		annotation SummarizationSetBy = Automatic

	partition Fact_DynastyRankingMetrics = m
		mode: import
		queryGroup: 'Fact Tables'
		source =
				let
				    Source = Parquet.Document(File.Contents("C:\Users\benha\OneDrive\Documents\GitHub\Python-PowerBI-DynastyFantasyFootball\data\fact_dynasty_ranking_metrics.parquet"), [Compression=null, LegacyColumnNameEncoding=false, MaxDepth=null])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

	annotation Synonyms = Dynasty Metrics|Ranking Metrics|Metric Facts|Dynasty Stats|Long Metrics

	annotation SynonymCollection = ["Dynasty Metrics","Ranking Metrics","Metric Facts","Dynasty Stats","Long Metrics"]

