	/// Average draft position at the latest snapshot, averaged across formats. Lower ADP means drafted earlier. Subtotal-correct across players (averaged). Same "composite_adp" fix as 'ADP' -- was filtering on a metric_key that doesn't exist.
	measure 'ADP (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "composite_adp" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: a7a41fcf-585b-4a8c-aa52-ab3dcb2d0cb2

		annotation Synonyms = adp|average draft position|draft position|draft cost|redraft adp

		annotation SynonymCollection = ["adp","average draft position","draft position","draft cost","redraft adp"]

	/// Dynasty startup average draft position at the latest snapshot, averaged across formats. Lower means drafted earlier. Subtotal-correct across players (averaged).
	measure 'Startup ADP (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "startup_adp" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: d4e1c0bd-0cb2-4573-9185-09d9541f2988

		annotation Synonyms = startup adp|startup draft position|dynasty adp|startup cost

		annotation SynonymCollection = ["startup adp","startup draft position","dynasty adp","startup cost"]

	/// Average auction value as a percent of budget at the latest snapshot, averaged across formats. Higher is more expensive. Subtotal-correct across players (averaged).
	measure 'Auction % (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "avg_auction_pct" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: b224b583-c66d-481d-9849-e54bdf3ea04a

		annotation Synonyms = auction value|auction percent|auction cost|budget percent|auction price

		annotation SynonymCollection = ["auction value","auction percent","auction cost","budget percent","auction price"]

	/// Dynasty startup auction value as a percent of budget at the latest snapshot, averaged across formats. Higher is pricier. Subtotal-correct across players (averaged).
	measure 'Startup Auction % (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "startup_avg_auction_pct" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 35dd1d2f-ca00-46ee-871b-1b27325c1572

		annotation Synonyms = startup auction|startup auction percent|dynasty auction|startup price

		annotation SynonymCollection = ["startup auction","startup auction percent","dynasty auction","startup price"]

	/// Market liquidity score at the latest snapshot, averaged across formats. Higher means more frequently traded. Subtotal-correct across players (averaged).
	measure 'Liquidity (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "std_liquidity" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: e607ca0e-948a-4752-aa79-d71db3224e71

		annotation Synonyms = liquidity|tradeability|market liquidity|trade frequency|marketability

		annotation SynonymCollection = ["liquidity","tradeability","market liquidity","trade frequency","marketability"]

	/// Overall value trend (change in trade value) at the latest snapshot, averaged across formats. Positive is rising. Subtotal-correct across players (averaged).
	measure 'Overall Trend (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "overall_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: ed73dc4b-2675-4798-911f-6b743d763d4b

		annotation Synonyms = trend|value trend|overall trend|momentum|value change

		annotation SynonymCollection = ["trend","value trend","overall trend","momentum","value change"]

	/// Positional value trend at the latest snapshot, averaged across formats. Positive means rising within position. Subtotal-correct across players (averaged).
	measure 'Pos. Trend (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "positional_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 819ec1d7-0b66-4dc4-a5f3-622ed06baa3d

		annotation Synonyms = positional trend|position trend|pos trend|positional momentum

		annotation SynonymCollection = ["positional trend","position trend","pos trend","positional momentum"]

	/// 7-day overall value trend at the latest snapshot, averaged across formats. Positive is rising this week. Subtotal-correct across players (averaged).
	measure 'Overall Trend (7d) (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "overall_7day_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: a2fa08b2-2a65-4fe2-9b99-9e78863b44a1

		annotation Synonyms = 7 day trend|weekly trend|recent trend|7d momentum|short term trend

		annotation SynonymCollection = ["7 day trend","weekly trend","recent trend","7d momentum","short term trend"]

	/// 7-day positional value trend at the latest snapshot, averaged across formats. Positive is rising this week. Subtotal-correct across players (averaged).
	measure 'Pos. Trend (7d) (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "positional_7day_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 35014fed-59a5-41c6-b12f-9b5be7d1e556

		annotation Synonyms = 7 day positional trend|weekly position trend|recent pos trend|7d position momentum

		annotation SynonymCollection = ["7 day positional trend","weekly position trend","recent pos trend","7d position momentum"]

	/// Count of times the player was kept in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Kept (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "kept" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 794d1d75-02b4-47a5-ac45-6abbb5117e98

		annotation Synonyms = kept|keep count|times kept|keepers|keep votes

		annotation SynonymCollection = ["kept","keep count","times kept","keepers","keep votes"]

	/// Count of times the player was traded in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Traded (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "traded" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 6fb274ad-0b71-49a5-9c51-eb2f1587f5a2

		annotation Synonyms = traded|trade count|times traded|trade votes

		annotation SynonymCollection = ["traded","trade count","times traded","trade votes"]

	/// Count of times the player was cut in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Cut (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "cut" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 843d4a44-7f86-41ff-bc04-add0895c7c6b

		annotation Synonyms = cut|cut count|times cut|drops|cut votes

		annotation SynonymCollection = ["cut","cut count","times cut","drops","cut votes"]

	/// Latest-snapshot scouting/analysis blurb for the player (text). Source: DynastySharks.
	measure Analysis =
			VAR _latest =
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[SnapshotDate] ), ALLSELECTED ( Fact_DynastyRankingMetrics[SnapshotDate] ) )
			RETURN
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[MetricText] ), Dim_DynastyMetric[MetricKey] = "analysis", Fact_DynastyRankingMetrics[SnapshotDate] = _latest )
		displayFolder: Dynasty Rankings
		lineageTag: e73e1239-68e8-4b7e-bade-3ac1c818ced4

		annotation Synonyms = analysis|blurb|scouting report|notes|writeup

		annotation SynonymCollection = ["analysis","blurb","scouting report","notes","writeup"]

	measure 'Dynasty Ranking - KTC Latest Snapshot' =
			
			CALCULATE( MAX(Fact_DynastyRankingMetrics[SnapshotDate]), Dim_DynastyMetric[SourceName] = "KTC")
		formatString: Short Date
		displayFolder: Formatting & References
		lineageTag: 94c88768-8fe5-46fc-9881-6c2e748bc131

	/// Player's cap hit as a percent of their team's total starting cap. Live calc against Fact_FantasyTeams + Dim_FantasyTeams[OriginalCap] -- no ETL-frozen rollup.
	measure 'Player Pct of Team Cap' =
			
			VAR PlayerCapHit =
			    [Active Roster Salary]
			
			VAR TeamTotalCap =
			    CALCULATE(
			        [Starting Salary Cap],
			        ALLEXCEPT('Dim_FantasyTeams', 'Dim_FantasyTeams'[TeamName])
			    )
			
			RETURN
			    DIVIDE(PlayerCapHit, TeamTotalCap, 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 1b7b8790-b0fd-4943-b181-4311669cf879

	/// This year's cap charge for a rostered (kept) player: the full ContractValue, no percentage applied. CapHitPct on Dim_Contract is a dead-money-only number -- it only prices what's still owed if you CUT the player (see the Dead Money measures below); it has no bearing on what a kept player costs. Minors-squad placement (RosterStatus = "Minors") is cap-exempt and excluded; blank RosterStatus charges normally. Same value as 'Contract Value', just season- and placement-filtered.
	measure 'Active Roster Salary' =

			CALCULATE(
			    SUM(Fact_FantasyTeams[ContractValue]),
			    Dim_Season[relative_nfl_season_number] = 0,
			    Fact_FantasyTeams[RosterStatus] <> "Minors"
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: f6e934e4-6811-44cf-ac61-1c3c7edd16fa

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Starting Salary Cap' = SUM(Dim_FantasyTeams[OriginalCap])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 13ef7dc7-b523-4094-bcde-9a46721b524f

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// original_cap - (active_roster_salary + dead_money + reinvestment_cap) -- same formula as discord_bot/capmath.py, computed live here so it responds to report filters (no cached Dim_FantasyTeams rollup exists anymore). Minors-squad placement (RosterStatus = "Minors") is cap-exempt, so its contract value does not reduce the remaining cap.
	measure 'Remaining Salary Cap' = [Starting Salary Cap] - CALCULATE ( [Contract Value], Fact_FantasyTeams[RosterStatus] <> "Minors" ) - [Dead Money - Active - Current Year] - SUM('Dim_FantasyTeams'[ReinvestmentCap])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: bfbe96fa-03d3-490f-a572-6dfb91da9c92

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Percent of Cap Remaining' = DIVIDE ( [Remaining Salary Cap], [Starting Salary Cap] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 6451e6d3-5723-4487-bd35-5c7af1895463

	measure 'Percent of Cap Used' = ```
			
			SWITCH ( 
			    TRUE(), 
			    NOT ISBLANK([Percent of Cap Remaining]),
			        1 - [Percent of Cap Remaining],
			    BLANK() 
			)
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 6eec5cc5-4191-4e2d-91c9-ac855c158cc1

	/// Total multi-year contract value of the active roster (not just this year's cap charge -- see 'Active Roster Salary' for that).
	measure 'Contract Value' = SUM(Fact_FantasyTeams[ContractValue])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 3280ec07-3c3a-47c1-8770-c8d7eaa1c62a

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Dead money = ContractValue x Dim_Contract[CapHitPct] -- CapHitPct only ever prices dead money, never the active cap hit (see 'Active Roster Salary'). ACTIVE means real: only counts players actually Cut on a Guaranteed contract -- this is what's really hitting the cap right now. SPECULATIVE (see below) drops the Cut requirement to answer "what would it cost to cut this player today," for planning before you pull the trigger. CURRENT YEAR = this season's Dim_Contract row's own CapHitPct.
	measure 'Dead Money - Active - Current Year' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        IF(
			            Fact_FantasyTeams[Status] = "Cut" && RELATED(Dim_Contract[Guaranteed]),
			            Fact_FantasyTeams[ContractValue] * RELATED(Dim_Contract[CapHitPct]),
			            0
			        )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: ccab9ac4-5f71-4ae1-a459-af6f37e399bd

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// NEXT YEAR = looks up the CapHitPct of (ContractType, TotalYears, ContractYear+1) in Dim_Contract -- e.g. a player on '1st' (initial, year 1) prices the '2nd' row's pct. Single-year contract types (Tag/X/Minor/FA) have no year+1 row, so this is 0 for them. ACTIVE = real: only Cut players on a Guaranteed contract. See 'Dead Money - Active - Current Year' for the full ACTIVE/SPECULATIVE explanation.
	measure 'Dead Money - Active - Next Year' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        VAR NextPct =
			            LOOKUPVALUE(
			                Dim_Contract[CapHitPct],
			                Dim_Contract[ContractType], RELATED(Dim_Contract[ContractType]),
			                Dim_Contract[TotalYears], RELATED(Dim_Contract[TotalYears]),
			                Dim_Contract[ContractYear], RELATED(Dim_Contract[ContractYear]) + 1
			            )
			        RETURN
			            IF(
			                Fact_FantasyTeams[Status] = "Cut" && RELATED(Dim_Contract[Guaranteed]) && NOT ISBLANK(NextPct),
			                Fact_FantasyTeams[ContractValue] * NextPct,
			                0
			            )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 2465b3f2-d177-4dcb-ad69-a6cf7d93e20a

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// TOTAL = sums CapHitPct across every remaining contract_year in the same (ContractType, TotalYears) cycle -- e.g. a player in year 1 of a 3-year 'initial' deal (.50/.40/.00) prices .50+.40+.00 = .90 x ContractValue. Uses ALL(Dim_Contract) to scan sibling contract-year rows outside the single-row relationship context. ACTIVE = real: only Cut players on a Guaranteed contract. See 'Dead Money - Active - Current Year' for the full ACTIVE/SPECULATIVE explanation.
	measure 'Dead Money - Active - Total' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        VAR CT = RELATED(Dim_Contract[ContractType])
			        VAR TY = RELATED(Dim_Contract[TotalYears])
			        VAR CY = RELATED(Dim_Contract[ContractYear])
			        VAR RemainingPct =
			            SUMX(
			                FILTER(
			                    ALL(Dim_Contract),
			                    Dim_Contract[ContractType] = CT
			                        && Dim_Contract[TotalYears] = TY
			                        && Dim_Contract[ContractYear] >= CY
			                ),
			                Dim_Contract[CapHitPct]
			            )
			        RETURN
			            IF(
			                Fact_FantasyTeams[Status] = "Cut" && RELATED(Dim_Contract[Guaranteed]),
			                Fact_FantasyTeams[ContractValue] * RemainingPct,
			                0
			            )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: f6a58ab2-6ba6-4cba-a848-5309d9bbc59e

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// SPECULATIVE CURRENT YEAR = same as 'Dead Money - Active - Current Year' but drops the Cut requirement (keeps Guaranteed), pricing what it WOULD cost to cut any rostered player today, not just players already dropped -- a what-if number for planning before pulling the trigger.
	measure 'Dead Money - Speculative - Current Year' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        IF(
			            RELATED(Dim_Contract[Guaranteed]),
			            Fact_FantasyTeams[ContractValue] * RELATED(Dim_Contract[CapHitPct]),
			            0
			        )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 2a522abd-aa42-4abe-81e3-27be8d82a8d2

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// SPECULATIVE NEXT YEAR = same as 'Dead Money - Active - Next Year' but drops the Cut requirement (keeps Guaranteed) -- what it would cost to cut this player next season if he's kept through this one.
	measure 'Dead Money - Speculative - Next Year' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        VAR NextPct =
			            LOOKUPVALUE(
			                Dim_Contract[CapHitPct],
			                Dim_Contract[ContractType], RELATED(Dim_Contract[ContractType]),
			                Dim_Contract[TotalYears], RELATED(Dim_Contract[TotalYears]),
			                Dim_Contract[ContractYear], RELATED(Dim_Contract[ContractYear]) + 1
			            )
			        RETURN
			            IF(
			                RELATED(Dim_Contract[Guaranteed]) && NOT ISBLANK(NextPct),
			                Fact_FantasyTeams[ContractValue] * NextPct,
			                0
			            )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 2d23f47b-42d9-41ef-b60b-8484652f1c28

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// SPECULATIVE TOTAL = same as 'Dead Money - Active - Total' but drops the Cut requirement (keeps Guaranteed) -- what it would cost to cut this player right now, for the whole remaining life of the contract cycle. The "should I cut this guy" number.
	measure 'Dead Money - Speculative - Total' =
			
			CALCULATE(
			    SUMX(
			        Fact_FantasyTeams,
			        VAR CT = RELATED(Dim_Contract[ContractType])
			        VAR TY = RELATED(Dim_Contract[TotalYears])
			        VAR CY = RELATED(Dim_Contract[ContractYear])
			        VAR RemainingPct =
			            SUMX(
			                FILTER(
			                    ALL(Dim_Contract),
			                    Dim_Contract[ContractType] = CT
			                        && Dim_Contract[TotalYears] = TY
			                        && Dim_Contract[ContractYear] >= CY
			                ),
			                Dim_Contract[CapHitPct]
			            )
			        RETURN
			            IF(
			                RELATED(Dim_Contract[Guaranteed]),
			                Fact_FantasyTeams[ContractValue] * RemainingPct,
			                0
			            )
			    ),
			    Dim_Season[relative_nfl_season_number] = 0
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 9b798d2d-afc0-40ce-9ed1-53a861fda9fc

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Player's Contract Value rank within their own team (1 = highest-paid), ignoring whatever player-level filter the visual currently has. ALLEXCEPT keeps only the TeamKey filter, so RANKX iterates every roster row on that team regardless of which players are otherwise shown. Not a Top N report filter (PBI's built-in Top N is global, not per-group) -- drag this into a visual's Filters pane and set "is less than or equal to 5" to get top-5-per-team in one chart.
	measure 'Contract Value Rank in Team' =
			
			RANKX(
			    ALLEXCEPT(Fact_FantasyTeams, Fact_FantasyTeams[TeamKey]),
			    [Contract Value]
			)
		formatString: 0
		displayFolder: Salary & Cap
		lineageTag: d3ca52a0-3638-4350-8318-8d9c3c5b4ea8

	/// Hidden placeholder column for this measure-only table. Not for reporting.
	column _Measures
		dataType: string
		isHidden
		lineageTag: a1b44d89-5f44-4f2f-bc55-f762d20c8b0b
		summarizeBy: none
		sourceColumn: _Measures

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	partition _Measures = m
		mode: import
		source =
				let
				    Source = ""
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

	annotation Synonyms = Measures|Dynasty Measures|Metrics|Calculations|KPIs

	annotation SynonymCollection = ["Measures","Dynasty Measures","Metrics","Calculations","KPIs"]

