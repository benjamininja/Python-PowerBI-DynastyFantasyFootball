/// Calculation-only table holding dynasty ranking measures (latest-snapshot, format-aware). No data columns.
table _Measures
	lineageTag: 57028ca8-1211-42cb-a1c2-3f3212eb23a5

	/// Raw sum of metric_num. Legacy matrix base; double-counts format-agnostic metrics. Prefer the per-metric measures.
	measure 'Metric Sum' = SUM ( Fact_DynastyRankingMetrics[MetricNum] )
		displayFolder: Dynasty Rankings
		lineageTag: b58aaced-ad1a-4f85-a2ec-10fbe60d1ed3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

		annotation Synonyms = metric sum|total metric|sum of metrics|raw metric total

		annotation SynonymCollection = ["metric sum","total metric","sum of metrics","raw metric total"]

	/// Count of times the player was cut in KeepTradeCut keep/trade/cut polling at the latest snapshot.
	measure 'Number Times Cut' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "cut" )
		formatString: #,##0
		displayFolder: Dynasty Rankings
		lineageTag: d7ea1fd4-00f6-4e49-a228-8c506bd336ec

		annotation Synonyms = cut|cut count|times cut|drops|cut votes

		annotation SynonymCollection = ["cut","cut count","times cut","drops","cut votes"]

	/// Count of times the player was kept in KeepTradeCut keep/trade/cut polling at the latest snapshot.
	measure 'Number Times Kept' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "kept" )
		formatString: #,##0
		displayFolder: Dynasty Rankings
		lineageTag: 36ec6eb5-e8a4-4440-a6bd-ef669e5b9761

		annotation Synonyms = kept|keep count|times kept|keepers|keep votes

		annotation SynonymCollection = ["kept","keep count","times kept","keepers","keep votes"]

	/// Count of times the player was traded in KeepTradeCut keep/trade/cut polling at the latest snapshot.
	measure 'Number Times Traded' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "traded" )
		formatString: #,##0
		displayFolder: Dynasty Rankings
		lineageTag: 071479af-4a91-47d9-b879-ab52c6616e77

		annotation Synonyms = traded|trade count|times traded|trade votes

		annotation SynonymCollection = ["traded","trade count","times traded","trade votes"]

	/// Share of keep/trade/cut votes that were cuts at the latest snapshot. Higher means more managers cut the player.
	measure 'Percent of Times Cut' =
			VAR denom_KTC = [Number Times Kept] + [Number Times Traded] + [Number Times Cut]
			RETURN
			DIVIDE ( [Number Times Cut], denom_KTC )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dynasty Rankings
		lineageTag: eac694cc-5cb7-4737-9b75-23f5850e0631

		annotation Synonyms = cut rate|percent cut|cut percentage|cut share

		annotation SynonymCollection = ["cut rate","percent cut","cut percentage","cut share"]

	/// Share of keep/trade/cut votes that were keeps at the latest snapshot. Higher means more managers keep the player.
	measure 'Percent of Times Kept' =
			VAR denom_KTC = [Number Times Kept] + [Number Times Traded] + [Number Times Cut]
			RETURN
			DIVIDE ( [Number Times Kept], denom_KTC )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dynasty Rankings
		lineageTag: c711a78f-dd1d-4d8b-9ce1-c9bcdca67299

		annotation Synonyms = keep rate|percent kept|keep percentage|keep share

		annotation SynonymCollection = ["keep rate","percent kept","keep percentage","keep share"]

	/// Share of keep/trade/cut votes that were trades at the latest snapshot.
	measure 'Percent of Times Traded' =
			VAR denom_KTC = [Number Times Kept] + [Number Times Traded] + [Number Times Cut]
			RETURN
			DIVIDE ( [Number Times Traded], denom_KTC )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Dynasty Rankings
		lineageTag: 1cbfa551-a23a-431e-a0c0-6198274f22db

		annotation Synonyms = trade rate|percent traded|trade percentage|trade share

		annotation SynonymCollection = ["trade rate","percent traded","trade percentage","trade share"]

	/// FantasyPros consensus average expert rank at the latest snapshot, averaged across formats. Lower rank is better.
	measure 'FP Avg Rank' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "avg" )
		formatString: 0
		displayFolder: Dynasty Rankings
		lineageTag: 5b3e9cf6-3e3e-4457-a5e6-60181fe2b233

		annotation Synonyms = average rank|consensus rank|expert rank|fp average|ecr

		annotation SynonymCollection = ["average rank","consensus rank","expert rank","fp average","ecr"]

	/// FantasyPros best (most optimistic) expert rank at the latest snapshot, averaged across formats. Lower is better.
	measure 'FP Best Rank' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "best" )
		formatString: 0
		displayFolder: Dynasty Rankings
		lineageTag: 3384acce-b2a2-4506-ad82-3bfa78877961

		annotation Synonyms = best rank|highest rank|ceiling rank|most optimistic|fp best

		annotation SynonymCollection = ["best rank","highest rank","ceiling rank","most optimistic","fp best"]

	/// FantasyPros worst (most pessimistic) expert rank at the latest snapshot, averaged across formats. Lower is better.
	measure 'FP Worst Rank' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "worst" )
		formatString: 0
		displayFolder: Dynasty Rankings
		lineageTag: 9258e26e-a3d7-4813-96c2-e8dc4bf090bc

		annotation Synonyms = worst rank|lowest rank|floor rank|most pessimistic|fp worst

		annotation SynonymCollection = ["worst rank","lowest rank","floor rank","most pessimistic","fp worst"]

	/// FantasyPros standard deviation of expert ranks at the latest snapshot, averaged across formats. Lower means more agreement.
	measure 'FP Std Dev' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "stddev" )
		formatString: 0.0
		displayFolder: Dynasty Rankings
		lineageTag: 3db94045-ef58-4d62-a46e-15c49834b8de

		annotation Synonyms = std dev|standard deviation|rank spread|disagreement|consensus spread

		annotation SynonymCollection = ["std dev","standard deviation","rank spread","disagreement","consensus spread"]

	/// Base: selected metric_num at the latest snapshot, averaged across formats in context. Player-grain building block.
	measure 'Metric Value' =
			VAR _latest =
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[SnapshotDate] ), ALLSELECTED ( Fact_DynastyRankingMetrics[SnapshotDate] ) )
			RETURN
			    CALCULATE ( AVERAGE ( Fact_DynastyRankingMetrics[MetricNum] ), Fact_DynastyRankingMetrics[SnapshotDate] = _latest )
		isHidden
		displayFolder: Dynasty Rankings\_base
		lineageTag: 4e46332c-29a8-4656-9048-3ad333380cf8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Base: averages the per-player metric value across all players in context (subtotal-correct for values and ranks).
	measure 'Metric Value Total' =
			VAR _latest =
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[SnapshotDate] ), ALLSELECTED ( Fact_DynastyRankingMetrics[SnapshotDate] ) )
			RETURN
			    AVERAGEX (
			        VALUES ( Fact_DynastyRankingMetrics[SourceUID] ),
			        CALCULATE ( AVERAGE ( Fact_DynastyRankingMetrics[MetricNum] ), Fact_DynastyRankingMetrics[SnapshotDate] = _latest )
			    )
		isHidden
		displayFolder: Dynasty Rankings\_base
		lineageTag: c797f2dc-bcac-45b3-aa6c-79af01f243f2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Base: sums the per-player metric value across all players in context (subtotal-correct for crowd counts).
	measure 'Metric Count Total' =
			VAR _latest =
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[SnapshotDate] ), ALLSELECTED ( Fact_DynastyRankingMetrics[SnapshotDate] ) )
			RETURN
			    SUMX (
			        VALUES ( Fact_DynastyRankingMetrics[SourceUID] ),
			        CALCULATE ( AVERAGE ( Fact_DynastyRankingMetrics[MetricNum] ), Fact_DynastyRankingMetrics[SnapshotDate] = _latest )
			    )
		isHidden
		displayFolder: Dynasty Rankings\_base
		lineageTag: 74f66c7a-7921-4c74-ab8e-7f05b326a830

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// KeepTradeCut superflex trade value at the latest snapshot, averaged across formats. Higher is better.
	measure 'KTC Value' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "value" )
		formatString: #,##0
		displayFolder: Dynasty Rankings
		lineageTag: f2366e35-07d3-4a97-bc60-10e5fc1601d0

		annotation Synonyms = ktc|trade value|ktc value|dynasty value|market value

		annotation SynonymCollection = ["ktc","trade value","ktc value","dynasty value","market value"]

	/// DynastySharks 3D Value+ score at the latest snapshot, averaged across formats. Higher is better.
	measure 'DS 3D Value+' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "ds_value" )
		formatString: 0.0
		displayFolder: Dynasty Rankings
		lineageTag: 36317d9f-e879-46c1-9b89-4f5f1faaad99

		annotation Synonyms = dynastysharks value|3d value|ds value|sharks value|dynasty value

		annotation SynonymCollection = ["dynastysharks value","3d value","ds value","sharks value","dynasty value"]

	/// Overall dynasty tier at the latest snapshot, averaged across formats. Lower tier number is better.
	measure 'Overall Tier' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "overall_tier" )
		formatString: 0
		displayFolder: Dynasty Rankings
		lineageTag: e27061cf-f025-48c2-8598-c741376e2200

