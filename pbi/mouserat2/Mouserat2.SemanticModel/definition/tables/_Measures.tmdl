	/// Average auction value as a percent of budget at the latest snapshot, averaged across formats. Higher is more expensive. Subtotal-correct across players (averaged).
	measure 'Auction % (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "avg_auction_pct" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: b224b583-c66d-481d-9849-e54bdf3ea04a

		annotation Synonyms = auction value|auction percent|auction cost|budget percent|auction price

		annotation SynonymCollection = ["auction value","auction percent","auction cost","budget percent","auction price"]

	/// Dynasty startup auction value as a percent of budget at the latest snapshot, averaged across formats. Higher is pricier. Subtotal-correct across players (averaged).
	measure 'Startup Auction % (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "startup_avg_auction_pct" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 35dd1d2f-ca00-46ee-871b-1b27325c1572

		annotation Synonyms = startup auction|startup auction percent|dynasty auction|startup price

		annotation SynonymCollection = ["startup auction","startup auction percent","dynasty auction","startup price"]

	/// Market liquidity score at the latest snapshot, averaged across formats. Higher means more frequently traded. Subtotal-correct across players (averaged).
	measure 'Liquidity (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "std_liquidity" )
		formatString: 0.0
		displayFolder: Dynasty Rankings - extra
		lineageTag: e607ca0e-948a-4752-aa79-d71db3224e71

		annotation Synonyms = liquidity|tradeability|market liquidity|trade frequency|marketability

		annotation SynonymCollection = ["liquidity","tradeability","market liquidity","trade frequency","marketability"]

	/// Overall value trend (change in trade value) at the latest snapshot, averaged across formats. Positive is rising. Subtotal-correct across players (averaged).
	measure 'Overall Trend (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "overall_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: ed73dc4b-2675-4798-911f-6b743d763d4b

		annotation Synonyms = trend|value trend|overall trend|momentum|value change

		annotation SynonymCollection = ["trend","value trend","overall trend","momentum","value change"]

	/// Positional value trend at the latest snapshot, averaged across formats. Positive means rising within position. Subtotal-correct across players (averaged).
	measure 'Pos. Trend (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "positional_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 819ec1d7-0b66-4dc4-a5f3-622ed06baa3d

		annotation Synonyms = positional trend|position trend|pos trend|positional momentum

		annotation SynonymCollection = ["positional trend","position trend","pos trend","positional momentum"]

	/// 7-day overall value trend at the latest snapshot, averaged across formats. Positive is rising this week. Subtotal-correct across players (averaged).
	measure 'Overall Trend (7d) (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "overall_7day_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: a2fa08b2-2a65-4fe2-9b99-9e78863b44a1

		annotation Synonyms = 7 day trend|weekly trend|recent trend|7d momentum|short term trend

		annotation SynonymCollection = ["7 day trend","weekly trend","recent trend","7d momentum","short term trend"]

	/// 7-day positional value trend at the latest snapshot, averaged across formats. Positive is rising this week. Subtotal-correct across players (averaged).
	measure 'Pos. Trend (7d) (total)' = CALCULATE ( [Metric Value Total], Dim_DynastyMetric[MetricKey] = "positional_7day_trend" )
		formatString: +0;-0;0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 35014fed-59a5-41c6-b12f-9b5be7d1e556

		annotation Synonyms = 7 day positional trend|weekly position trend|recent pos trend|7d position momentum

		annotation SynonymCollection = ["7 day positional trend","weekly position trend","recent pos trend","7d position momentum"]

	/// Count of times the player was kept in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Kept (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "kept" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 794d1d75-02b4-47a5-ac45-6abbb5117e98

		annotation Synonyms = kept|keep count|times kept|keepers|keep votes

		annotation SynonymCollection = ["kept","keep count","times kept","keepers","keep votes"]

	/// Count of times the player was traded in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Traded (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "traded" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 6fb274ad-0b71-49a5-9c51-eb2f1587f5a2

		annotation Synonyms = traded|trade count|times traded|trade votes

		annotation SynonymCollection = ["traded","trade count","times traded","trade votes"]

	/// Count of times the player was cut in KeepTradeCut keep/trade/cut polling at the latest snapshot. Subtotal-correct across players (summed).
	measure 'Number Times Cut (total)' = CALCULATE ( [Metric Count Total], Dim_DynastyMetric[MetricKey] = "cut" )
		formatString: #,##0
		displayFolder: Dynasty Rankings - extra
		lineageTag: 843d4a44-7f86-41ff-bc04-add0895c7c6b

		annotation Synonyms = cut|cut count|times cut|drops|cut votes

		annotation SynonymCollection = ["cut","cut count","times cut","drops","cut votes"]

	/// Latest-snapshot scouting/analysis blurb for the player (text). Source: DynastySharks.
	measure Analysis =
			VAR _latest =
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[SnapshotDate] ), ALLSELECTED ( Fact_DynastyRankingMetrics[SnapshotDate] ) )
			RETURN
			    CALCULATE ( MAX ( Fact_DynastyRankingMetrics[MetricText] ), Dim_DynastyMetric[MetricKey] = "analysis", Fact_DynastyRankingMetrics[SnapshotDate] = _latest )
		displayFolder: Dynasty Rankings
		lineageTag: e73e1239-68e8-4b7e-bade-3ac1c818ced4

		annotation Synonyms = analysis|blurb|scouting report|notes|writeup

		annotation SynonymCollection = ["analysis","blurb","scouting report","notes","writeup"]

	measure 'Dynasty Ranking - KTC Latest Snapshot' =
			
			CALCULATE( MAX(Fact_DynastyRankingMetrics[SnapshotDate]), Dim_DynastyMetric[SourceName] = "KTC")
		formatString: Short Date
		displayFolder: Formatting & References
		lineageTag: 94c88768-8fe5-46fc-9881-6c2e748bc131

	/// Player's cap hit as a percent of their team's total starting cap. Live calc against Fact_FantasyTeams + Dim_FantasyTeams[OriginalCap] -- no ETL-frozen rollup.
	measure 'Player Pct of Team Cap' =

			VAR PlayerCapHit =
			    [Active Roster Salary]

			VAR TeamTotalCap =
			    CALCULATE(
			        [Starting Salary Cap],
			        ALLEXCEPT('Dim_FantasyTeams', 'Dim_FantasyTeams'[TeamName])
			    )
			
			RETURN
			    DIVIDE(PlayerCapHit, TeamTotalCap, 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 1b7b8790-b0fd-4943-b181-4311669cf879

	/// This-year cap charge for the active roster: ContractValue x Dim_Contract[CapHitPct] via the ContractID relationship, not a stored CapHit column (removed 2026-07-11 -- 100% derivable, was a redundant duplicate of the same math). Same formula as the Discord bot's discord_bot/capmath.py -- see 'Contract Value' for total deal size instead.
	measure 'Active Roster Salary' = SUMX(Fact_FantasyTeams, Fact_FantasyTeams[ContractValue] * RELATED(Dim_Contract[CapHitPct]))
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: f6e934e4-6811-44cf-ac61-1c3c7edd16fa

	measure 'Starting Salary Cap' = SUM(Dim_FantasyTeams[OriginalCap])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 13ef7dc7-b523-4094-bcde-9a46721b524f

	/// original_cap - (active_roster_salary + dead_money + reinvestment_cap) -- same formula as discord_bot/capmath.py, computed live here so it responds to report filters (no cached Dim_FantasyTeams rollup exists anymore).
	measure 'Remaining Salary Cap' = [Starting Salary Cap] - [Active Roster Salary] - [Dead Money Active - Current Year] - SUM('Dim_FantasyTeams'[ReinvestmentCap])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: bfbe96fa-03d3-490f-a572-6dfb91da9c92

	measure 'Percent of Cap Remaining' = DIVIDE ( [Remaining Salary Cap], [Starting Salary Cap] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 6451e6d3-5723-4487-bd35-5c7af1895463

	measure 'Percent of Cap Used' = 1 - [Percent of Cap Remaining]
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Salary & Cap
		lineageTag: 6eec5cc5-4191-4e2d-91c9-ac855c158cc1

	/// Total multi-year contract value of the active roster (not just this year's cap charge -- see 'Active Roster Salary' for that).
	measure 'Contract Value' = SUM(Fact_FantasyTeams[ContractValue])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: 3280ec07-3c3a-47c1-8770-c8d7eaa1c62a

	/// Dead money charged against the cap from dropped players. Lives on Fact_FantasyTeams (contract-value grain); Dim_Contract only holds the guarantee rule that determines whether a dropped contract carries dead money.
	measure 'Dead Money Active - Current Year' = ```
			
			SWITCH(TRUE,
			    SELECTEDVALUE('Fact_FantasyTeams'[Status]) = "Active", 0,
			    
			    SUM(Fact_FantasyTeams[ContractValue]) * SELECTEDVALUE(Dim_Contract[CapHitPct])
			)
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: ccab9ac4-5f71-4ae1-a459-af6f37e399bd

	measure 'Dead Money Cap Hit - Current Year' = SELECTEDVALUE(Fact_FantasyTeams[ContractValue]) * SELECTEDVALUE(Dim_Contract[CapHitPct])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Salary & Cap
		lineageTag: bc17c6c7-510c-4ace-aab5-4d0e341a16f9

	/// Hidden placeholder column for this measure-only table. Not for reporting.
	column _Measures
		dataType: string
		isHidden
		lineageTag: a1b44d89-5f44-4f2f-bc55-f762d20c8b0b
		summarizeBy: none
		sourceColumn: _Measures

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	partition _Measures = m
		mode: import
		source =
				let
				    Source = ""
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

	annotation Synonyms = Measures|Dynasty Measures|Metrics|Calculations|KPIs

	annotation SynonymCollection = ["Measures","Dynasty Measures","Metrics","Calculations","KPIs"]

