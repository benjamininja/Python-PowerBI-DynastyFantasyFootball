		annotation SynonymCollection = ["10 year projection","ten year","proj 10yr","career projection","long term value"]

	/// Average draft position at the latest snapshot, averaged across formats. Lower ADP means drafted earlier. Uses the blended Composite ADP across all dynasty sources (metric_key "composite_adp") -- fixed 2026-07-11, was filtering on "adp", a metric_key that doesn't exist in dim_dynasty_metric (real keys are ktc_adp/ds_adp/composite_adp/startup_adp), so this measure was always blank everywhere, not just alongside salary fields. IsRosterRow gate added 2026-07-11: Dim_Contract is a 10-row rule lookup (1st/2nd/.../FA) unrelated to Fact_DynastyRankingMetrics, so ADP ignores the Contract row filter and returns the same player value regardless of which contract row is in context. The 9999 sentinel used to fill in for every one of those 10 rows per player (not just their real contract), and a non-blank measure defeats the matrix's blank-row suppression -- so every player showed all 10 phantom contract combinations with blank salary fields next to a repeated ADP. Gating on COUNTROWS(Fact_FantasyTeams) > 0 restores blank on the 9 non-matching combos so they go back to being suppressed, and only fills 9999 on the one real roster row.
	measure ADP =
			
			VAR adp = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "composite_adp" )
			VAR IsRosterRow = COUNTROWS ( Fact_FantasyTeams ) > 0
			
			RETURN
			SWITCH( TRUE(),
			NOT IsRosterRow, BLANK(),
			NOT ISBLANK(adp), adp,
			9999.0)
		formatString: 0.0
		displayFolder: Dynasty Rankings
		lineageTag: a5a5728e-d719-481f-85cd-ac8fd670dab1

		annotation Synonyms = adp|average draft position|draft position|draft cost|redraft adp

		annotation SynonymCollection = ["adp","average draft position","draft position","draft cost","redraft adp"]

	/// Dynasty startup average draft position at the latest snapshot, averaged across formats. Lower means drafted earlier.
	measure 'Startup ADP' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "startup_adp" )
		formatString: 0.0
		displayFolder: Dynasty Rankings
		lineageTag: 687543b4-a2b0-4eb8-a861-e401ef7d43e3

		annotation Synonyms = startup adp|startup draft position|dynasty adp|startup cost

		annotation SynonymCollection = ["startup adp","startup draft position","dynasty adp","startup cost"]

