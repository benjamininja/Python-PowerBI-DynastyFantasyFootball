	/// 7-day overall value trend at the latest snapshot, averaged across formats. Positive is rising this week.
	measure 'Overall Trend (7d)' = CALCULATE ( [Metric Value], Dim_DynastyMetric[MetricKey] = "overall_7day_trend" )
