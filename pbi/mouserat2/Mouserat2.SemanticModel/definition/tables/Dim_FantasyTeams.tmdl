	column RemainingCapCurrentYr
		dataType: int64
		formatString: 0
		lineageTag: 77f0e2d1-e927-4920-9867-14398d55b4a2
		summarizeBy: none
		sourceColumn: remaining_cap_current_yr

		annotation SummarizationSetBy = User

		annotation Synonyms = remaining cap|cap space|space left

		annotation SynonymCollection = ["remaining cap","cap space","space left"]

	/// Cap space remaining next year ($).
	column RemainingCapNextYr
		dataType: int64
		formatString: 0
		lineageTag: ca9bead2-1773-4f32-9e46-976580f86692
