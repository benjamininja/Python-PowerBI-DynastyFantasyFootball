# Copy to .env at the repo root and fill in real values. .env is gitignored.

# Fantrax login for the headless scrapers (04a/04v/04w).
FANTRAX_EMAIL=you@example.com
FANTRAX_PASSWORD=your-password

# Optional: Discord webhook for pipeline run summaries (scripts/run_pipeline.py).
# Create in a private channel: Channel Settings > Integrations > Webhooks.
DISCORD_WEBHOOK_URL=
