# ── Playwright session (contains browser tokens / secrets) ───────────────────
data/.pw_profile/
# ── Unneccessary ─────────────────────────────────────────────────────────────
data/raw/
data/review/
data/outputs/
skills/

# ── Credentials ───────────────────────────────────────────────────────────────
# Ignore every .env anywhere: bare, prefixed (foo.env), and dotted (.env.local,
# .env.production) at any directory depth. Keep .env.example tracked as a template.
.env
*.env
.env.*
!.env.example
!**/.env.example
api_key.txt

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
.botvenv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/settings.json
# Claude Code per-developer local settings (permissions allowlist etc.) — not shared.
.claude/settings.local.json

# ── Power BI project (PBIP) local artifacts ───────────────────────────────────
**/.pbi/
*.abf
# Auto-generated time-intelligence tables — Power BI recreates these on open.
**/LocalDateTable_*.tmdl
**/DateTableTemplate_*.tmdl