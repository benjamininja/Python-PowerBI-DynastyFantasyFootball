# Copy to discord_bot/.env and fill in real values. .env is gitignored.
# In production these are set as Railway service variables (not committed).

# Discord bot token — Developer Portal > Bot > Reset Token (NOT a user token).
DISCORD_BOT_TOKEN=your-bot-token-here
# League server (guild) id — enable Developer Mode, right-click server > Copy ID.
DISCORD_GUILD_ID=000000000000000000

# Fine-grained PAT: Contents = Read-only, this repo only. No write scopes.
GITHUB_PAT=github_pat_xxx
GITHUB_OWNER=benjamininja
GITHUB_REPO=Python-PowerBI-DynastyFantasyFootball
GITHUB_REF=main

# Optional: prefix for prefix-style commands (default "!").
DISCORD_COMMAND_PREFIX=!
